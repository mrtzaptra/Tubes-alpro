func HitungSkor(L Lowongan, A dataDIri) int { // Hitung kecocokan
	var skor, i, j int
	skor = 0
	for i = 0; i < 4; i++ {
		if L.SyaratSkill[i] != "" {
			for j = 0; j < 12; j++ {
				if A.skil[j] != "" && A.skil[j] == L.SyaratSkill[i] {
					skor++
				}
			}
		}
	}
	return skor
}

func InsertionSortCocok(arr *[10]LowonganSkor, asc bool) {
	var i, j int
	var key LowonganSkor

	for i = 1; i < 10; i++ {
		key = arr[i]
		j = i - 1

		if asc {
			for j >= 0 && arr[j].Skor > key.Skor {
				arr[j+1] = arr[j]
				j = j - 1
			}
		} else {
			for j >= 0 && arr[j].Skor < key.Skor {
				arr[j+1] = arr[j]
				j = j - 1
			}
		}
		arr[j+1] = key
	}
}

