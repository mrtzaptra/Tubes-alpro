func BuatData(A *dataDIri, tes *Nitip) {
	var er error

	fmt.Println("===== Membuat Data Diri ======")
	if tes.name { // Input Nama
		fmt.Print("Nama : ")
		A.nama = Input()
	}

	if tes.penga { // Input Pengalaman
		fmt.Print("Pengalaman ada berapa?(max 5):")
		var i int
		var input string
		var n int
		fmt.Scan(&n)
		fmt.Scanln()
		if n > 5 {
			n = 5
		}
		for i = 0; i < n; i++ {
			fmt.Printf("%d. ", i+1)
			input = Input()
			A.pengalaman[i] = input
		}
		tes.pengalamanN = n
	}

	if tes.pend { // Input Pendidikan
		fmt.Println("Pendidikan terakhir di '1'(SMA/S1/S2) :")
		var i int
		var hasil string
		for i < 2 {
			fmt.Printf("%d. ", i+1)
			hasil = Input()
			if cekpend(hasil) {
				A.pendidikan[i] = hasil
				i++
			}

		}
	}

	if tes.skill { // Input Skill
		var cekdata int = -1
		var i int
		var listskill [12]string = getListSkill()
		tes.skilN = 0
		listSkill()
		fmt.Print("\n(Berhenti di 0,Contoh 1 4 5 0) \nJika format/angka tidak sesuai tidak tebaca\nPilih :")
		for {
			er = nil
			_, er = fmt.Scan(&cekdata)
			if cekdata == 0 {
				break
			}
			if er == nil && cekdata >= 0 && cekdata <= 12 {
				A.skil[i] = listskill[cekdata-1]
				tes.skilN++
				i++
			}
		}
		fmt.Scanln()
	}

	fmt.Print("\nData berhasil disimpan ✅\nlanjut? Enter :")
	fmt.Scanln()
}

