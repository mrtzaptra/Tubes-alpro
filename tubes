func CariSequential(kata string) { // Kata Kunci industri (Sequential Search)
	var ketemu bool = false
	var i int

	fmt.Printf("\n=== Hasil Pencarian Industri: %s ===\n", kata)
	for i = 0; i < 10; i++ {
		if daftarLowongan[i].Industri == kata {
			fmt.Printf("- ID: %d | %s | Rp%d\n",
				daftarLowongan[i].ID, daftarLowongan[i].Posisi, daftarLowongan[i].Gaji)
			ketemu = true
		}
	}
	if !ketemu {
		fmt.Println("Tidak ada lowongan di industri tersebut.")
	}
	fmt.Print("\nSelesai ✅, Enter :")
	fmt.Scanln()
}

func CariBinary(id int) { // Id lowongan (Binary Search)
	var kiri, kanan, tengah, i int
	var ketemu bool = false
	kiri = 0
	kanan = 9
	fmt.Printf("\n=== Mencari Lowongan dengan ID %d ===\n", id)

	for kiri <= kanan && !ketemu {
		tengah = (kiri + kanan) / 2
		if daftarLowongan[tengah].ID == id {
			ketemu = true
		} else if daftarLowongan[tengah].ID < id {
			kiri = tengah + 1
		} else {
			kanan = tengah - 1
		}
	}

	if ketemu {
		fmt.Printf(`✅ Lowongan Ditemukan!
Posisi    : %s
Industri  : %s
Gaji      : Rp %d
Deskripsi : %s
`, daftarLowongan[tengah].Posisi, daftarLowongan[tengah].Industri,
daftarLowongan[tengah].Gaji, daftarLowongan[tengah].Deskripsi)

		fmt.Print("Syarat    : ")
		for i = 0; i < 4; i++ {
			if daftarLowongan[tengah].SyaratSkill[i] != "" {
				fmt.Printf("[%s] ", daftarLowongan[tengah].SyaratSkill[i])
			}
		}
		fmt.Println()
	} else {
		fmt.Println("ID Lowongan tidak ditemukan. ❌ :|")
	}

	fmt.Print("\nSelesai ✅, Enter :")
	fmt.Scanln()
}

func urutGaji() {
	var pilih int
