func Hapus(A *dataDIri, tes *Nitip) {
	var i, n int
	if tes.penga { // Pengalaman
		fmt.Println("\n=== Pengalaman ===")
		for i = 0; i < tes.pengalamanN; i++ {
			fmt.Printf("%d. %s\n", i+1, A.pengalaman[i])
		}
		fmt.Print("Pilih : ")
		fmt.Scan(&n)
		for n > tes.pengalamanN {
			fmt.Println("Harus pilih yang ada di pilihan..")
			fmt.Scan(&n)
		}
		for i = (n - 1); i < (tes.pengalamanN - 1); i++ {
			A.pengalaman[i] = A.pengalaman[i+1]
		}
		tes.pengalamanN--
	} else if tes.skill { // Skill
		fmt.Println("\n=== Skils ===")
		for i = 0; i < tes.skilN; i++ {
			fmt.Printf("%d. %s\n", i+1, A.skil[i])
		}
		fmt.Print("\nPilih : ")
		fmt.Scan(&n)
		for n > tes.skilN {
			fmt.Println("Harus pilih yang ada di pilihan..")
			fmt.Scan(&n)
		}
		for i = (n - 1); i < (tes.skilN - 1); i++ {
			A.skil[i] = A.skil[i+1]
		}
		tes.skilN--
	}
	fmt.Scanln()
	fmt.Print("\nSelesai ✅, Enter :")
	fmt.Scanln()
}

func tambah(A *dataDIri, tes *Nitip) {
	var n, i, Nfinal int
	var masukan string
	if tes.penga {
		fmt.Printf("Tambah berapa(%d [max 5])?", tes.pengalamanN)
		fmt.Scan(&n)
		fmt.Scanln()
		Nfinal = tes.pengalamanN + n
		if Nfinal > 5 {
			Nfinal = 5
		}
		for i = tes.pengalamanN; i < Nfinal; i++ {
			masukan = Input()
			A.pengalaman[i] = masukan
		}
		tes.pengalamanN = Nfinal
	} else if tes.skill {
		var cekdata int = -1
		var er error
		var listskill [12]string = getListSkill()
		i = tes.skilN
		listSkill()
		fmt.Print("\n(Berhenti di 0,Contoh 1 4 5 0) \nJika format/angka tidak sesuai tidak tebaca\nPilih :")
		for {
			er = nil
			_, er = fmt.Scan(&cekdata)
			if cekdata == 0 {
				break
			}
			if er == nil && cekdata >= 0 && cekdata <= 12 {
				A.skil[i] = listskill[cekdata-1]
				tes.skilN++
				i++
			}
		}
		fmt.Scanln()
	}
	fmt.Print("\nSelesai ✅, Enter :")
	fmt.Scanln()
}

