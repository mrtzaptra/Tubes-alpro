func cekpend(hasil string) bool {
	if len(hasil) >= 3 && hasil[:3] == "SMA" {
		return true
	} else if len(hasil) >= 2 && (hasil[:2] == "S1" || hasil[:2] == "S2") {
		return true
	} else {
		fmt.Print("Opss harus pilih yang di opsi.. \n")
		return false
	}
}

func Input() string {
	var result string
	var char rune
	var err error

	for {
		_, err = fmt.Scanf("%c", &char)

		if err != nil || char == '\n' {
			break
		}
		if char != '\r' {
			result += string(char)
		}
	}
	return result

}
