	fmt.Scan(&pilih)

	fmt.Scanln()
	switch pilih {
	case 1:
		SelectionSortGaji(&urutlowongan, true)
		fmt.Println("\n✅ Berhasil diurutkan (Terkecil - Terbesar).")
	case 2:
		SelectionSortGaji(&urutlowongan, false)
		fmt.Println("\n✅ Berhasil diurutkan (Terbesar - Terkecil).")
	}

	TampilHasil(urutlowongan)
}

func SelectionSortGaji(Low *[10]Lowongan, kecil bool) {
	var i, j, idx int
	var temp Lowongan

	for i = 0; i < 9; i++ {
		idx = i
		for j = i + 1; j < 10; j++ {
			if kecil {
				if Low[j].Gaji < Low[idx].Gaji {
					idx = j
				}
			} else {
				if Low[j].Gaji > Low[idx].Gaji {
					idx = j
				}
			}
		}
		temp = Low[i]
		Low[i] = Low[idx]
		Low[idx] = temp
	}
}

