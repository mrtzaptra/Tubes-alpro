func BeriEvaluasi(A dataDIri, L Lowongan) {
	var matchCount, reqCount, persentase int
	var missingSkills [4]string
	var missIdx int
	var i, j int
	var found bool

	for i = 0; i < 4; i++ {
		if L.SyaratSkill[i] != "" {
			reqCount++
			found = false

			for j = 0; j < 12 && !found; j++ {
				if A.skil[j] == L.SyaratSkill[i] {
					found = true
				}
			}
			if found {
				matchCount++
			} else {
				missingSkills[missIdx] = L.SyaratSkill[i]
				missIdx++
			}
		}
	}

	if reqCount > 0 {
		persentase = (matchCount * 100) / reqCount
	} else {
		persentase = 100
	}

	clear()
	fmt.Printf("=== RINGKASAN EVALUASI AI 🤖 ===\n")
	fmt.Printf("Pelamar             : %s\n", A.nama)
	fmt.Printf("Posisi yang dilamar : %s (%s)\n", L.Posisi, L.Industri)
	fmt.Printf("Tingkat Kesesuaian  : %d%%\n", persentase)
	fmt.Println("==================================\n")

	fmt.Println("Pesan AI & Saran Perbaikan :")
	if persentase == 100 {
		fmt.Println("LUAR BIASA! Anda SANGAT COCOK dengan posisi ini 🌟")
		fmt.Println("-> Saran Resume: Pertahankan! Pastikan pengalaman Anda menonjolkan semua skill yang disyaratkan.")
		fmt.Println("-> Saran Surat Lamaran: Anda bisa langsung menggunakan fitur 'Buat Surat Lamaran' sekarang.")
	} else if persentase >= 50 {
		fmt.Println("Anda CUKUP COCOK, namun ada celah kompetensi 👍")
		fmt.Print("-> Saran Perbaikan Resume: Sebaiknya Anda mulai mempelajari dan menambahkan skill berikut ke resume Anda: ")
		for i = 0; i < missIdx; i++ {
			fmt.Printf("[%s] ", missingSkills[i])
		}
		fmt.Println()
		fmt.Println("-> Saran Surat Lamaran: Di surat lamaran nanti, fokus ceritakan pengalaman problem-solving Anda untuk menutupi kekurangan skill teknis di atas.")
	} else {
		fmt.Println("Anda KURANG COCOK dengan kriteria utama posisi ini 👍")
		fmt.Println("-> Saran Perbaikan Resume: Resume Anda saat ini tidak akan lolos seleksi otomatis (ATS).")
		fmt.Println("-> Langkah Lanjutan: Tunda mengirim surat lamaran. Fokuslah membangun portofolio dengan teknologi ini terlebih dahulu:")
		for i = 0; i < missIdx; i++ {
			fmt.Printf("   • %s\n", missingSkills[i])
		}
	}
	fmt.Print("\nSelesai ✅, Enter untuk kembali :")
	fmt.Scanln()
}

